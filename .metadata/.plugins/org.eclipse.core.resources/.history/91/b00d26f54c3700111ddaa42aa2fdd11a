package com.exception.whatIsException;

public class Try_catch_finally {
	
	public static void main(String[] args) {
		
		try {
//			System.out.println(2/0); 
			System.out.println(2/2);
			
//			return ;   // return likha to bhi finally chalega hi
			System.exit(0);  // yeh jvm ko stop karta iske bad kuch bhi nahi chalta
			
		}
		catch (Exception e) {
			System.out.println("Arithmatic Exception Occured");
		}
		finally {
			System.out.println("Finally block Excecuted");
		}
	}
}
